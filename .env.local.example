# Supabase 프로젝트 설정 → API 에서 복사
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요. (.env* 는 git 무시됨)

# 공개 키 (브라우저 노출 OK)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 서비스롤 키 — 절대 클라이언트/깃에 노출 금지.
# 강사 '삭제', 비로그인 숙제 제출 업로드, 미제출자 실번호 조회에 서버에서 사용.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# 문자/알림톡 발송 (Solapi). 비워두면 mock 모드로 동작(실제 발송 없이 시뮬레이션).
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=01000000000
